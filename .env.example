# ─── InstantDB (Instant Cloud) ───────────────────────────────
# Get your app ID and admin token from https://instantdb.com
NEXT_PUBLIC_INSTANT_APP_ID=
# Server-side admin SDK (can be omitted if same as NEXT_PUBLIC_INSTANT_APP_ID)
INSTANT_APP_ID=
INSTANT_APP_ADMIN_TOKEN=

# Uncomment only when using a self-hosted InstantDB backend:
# NEXT_PUBLIC_INSTANT_API_URI=http://localhost:8888
# NEXT_PUBLIC_INSTANT_WEBSOCKET_URI=ws://localhost:8888/runtime/session

# ─── Device Access ───────────────────────────────────────────
# Shared secret for device activation (generate a random string)
DEVICE_ACCESS_KEY=

# ─── Apple Calendar Sync (server-only) ─────────────────────
# Encrypts stored Apple app-specific passwords at rest.
CALDAV_CREDENTIAL_ENCRYPTION_KEY=
# Rotate only when you also handle re-encryption of stored credentials.
CALDAV_CREDENTIAL_ENCRYPTION_KEY_VERSION=v1
# Used by cron or the optional polling worker to call the sync endpoint.
CALENDAR_SYNC_CRON_SECRET=

# Optional Apple Calendar sync tuning
# APPLE_CALDAV_SYNC_WINDOW_PAST_DAYS=90
# APPLE_CALDAV_SYNC_WINDOW_FUTURE_DAYS=365
# APPLE_CALDAV_REPAIR_SCAN_INTERVAL_HOURS=24
# APPLE_CALDAV_LOCK_TTL_MINUTES=20
# APPLE_CALDAV_POLL_BASE_SECONDS=15
# APPLE_CALDAV_POLL_MAX_IDLE_SECONDS=300
# APPLE_CALDAV_POLL_ERROR_SECONDS=30
# APPLE_CALDAV_POLL_MAX_ERROR_SECONDS=300
# Refresh cached Apple calendar discovery metadata on this cadence.
# APPLE_CALDAV_DISCOVERY_REFRESH_HOURS=12
# Optional worker target when using `npm run calendar-sync:worker`.
# APPLE_CALDAV_POLL_TARGET_URL=http://localhost:3000
# Legacy alias for the worker target.
# APPLE_CALDAV_SYNC_BASE_URL=http://localhost:3000

# ─── S3 / MinIO File Storage ────────────────────────────────
# Public endpoint (used by the browser for presigned URLs).
# Set to the externally-reachable URL of your MinIO/S3 instance.
NEXT_PUBLIC_S3_ENDPOINT=https://s3.example.com
# Server-side endpoint (used by Next.js server).
# docker-compose.yml overrides this to http://minio:9000 for internal traffic.
# For non-Docker setups, set to the same as NEXT_PUBLIC_S3_ENDPOINT.
S3_ENDPOINT=https://s3.example.com
S3_BUCKET_NAME=family-organizer
# Change these from the defaults before deploying!
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin

# ─── Docker Compose ─────────────────────────────────────────
# MinIO ports exposed on the host. Required if you access MinIO directly;
# can be removed if MinIO is only accessed internally by the app container.
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
# The app container does not expose a host port by default — a reverse proxy
# (e.g. SWAG) can reach it directly as http://family-organizer:3000.
# To expose the app on the host directly instead, uncomment in docker-compose.yml:
#   ports:
#     - '7654:3000'
# Set if you reverse-proxy the MinIO console (e.g. via SWAG/nginx).
# MINIO_BROWSER_REDIRECT_URL=https://console-s3.example.com

# Name of an existing Docker network to join (e.g. for reverse proxying via SWAG/nginx).
# The network must already exist: docker network create <name>
DOCKER_NETWORK_NAME=docker_default

# ─── Local Dev / Mobile (not needed on a deployed server) ───
# Expo Go base URL: set to your dev machine so the phone can reach Next.js.
# EXPO_PUBLIC_API_BASE_URL=http://your-machine.local:3000
# EXPO_PUBLIC_INSTANT_APP_ID=  # falls back to NEXT_PUBLIC_INSTANT_APP_ID

# ─── Optional Tuning ────────────────────────────────────────
# Parent shared-device idle timeout (default: 15 min)
# NEXT_PUBLIC_PARENT_SHARED_DEVICE_IDLE_TIMEOUT_MS=900000
# Parent elevation brute-force backoff
# PARENT_ELEVATION_RATE_LIMIT_FREE_FAILURES=3
# PARENT_ELEVATION_RATE_LIMIT_BASE_BACKOFF_MS=1000
# PARENT_ELEVATION_RATE_LIMIT_MAX_BACKOFF_MS=300000
# PARENT_ELEVATION_RATE_LIMIT_WINDOW_MS=600000

# ─── Self-Hosted InstantDB (advanced) ───────────────────────
# Only needed if running your own InstantDB server instead of Instant Cloud.
# See https://github.com/instantdb/instant for self-hosted setup.
# These configure the Instant server itself, not this app.
# INSTANT_JWT_SECRET=
# INSTANT_SESSION_SECRET=
# INSTANT_DB_PASSWORD=
# INSTANT_APP_SECRET=
